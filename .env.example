# ──────────────────────────────────────────────────────────────────
# ORRERY — environment variables (MVP / Tier 1)
# Copy to .env.local (web app) and/or .env (Python pipeline) and fill in.
# NEVER commit real keys. The service role key is server + pipeline ONLY
# and must never reach the browser.
# ──────────────────────────────────────────────────────────────────

# ── Supabase ────────────────────────────────────────────────
# Project URL, e.g. https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Publishable / anon key — safe for the browser (reads are gated by RLS).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role (secret) key — server + pipeline ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres connection string for the pipeline + CLI (psql / Splink writes),
# e.g. postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
SUPABASE_DB_URL=
# Project ref (the <ref> in the URLs above) — used by the Supabase CLI.
SUPABASE_PROJECT_REF=

# ── Anthropic (metered API; separate from your Claude Code/Max subscription) ──
# Used ONLY for extraction, ambiguous-match adjudication, and on-demand summaries.
ANTHROPIC_API_KEY=

# ── Companies House (free; rate limit 600 requests / 5 min) ──
COMPANIES_HOUSE_API_KEY=

# Electoral Commission: no key needed (CSV downloads).
# UK Parliament APIs: no key needed (Open Parliament Licence).

# ──────────────────────────────────────────────────────────────────
# Tier 2 — add when the MVP works (leave blank for now)
# ──────────────────────────────────────────────────────────────────
# THEYWORKFORYOU_API_KEY=
# OPENSANCTIONS_API_KEY=
# OPENCORPORATES_API_KEY=
# ALEPH_API_KEY=
# NEO4J_URI=
# NEO4J_USERNAME=
# NEO4J_PASSWORD=

# ──────────────────────────────────────────────────────────────────
# Tier 3 — productionise / monetise (much later)
# ──────────────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
